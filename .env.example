# Copy to .env for local dev. Never commit the real .env.
# On Railway these are set as service variables, not from a file.

# --- Required: the five agents ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Required: x402 paid endpoints (OKX facilitator) ---
# Without these the process exits at startup rather than serving paid tools free.
OKX_PAY_API_KEY=
OKX_PAY_SECRET_KEY=
OKX_PAY_PASSPHRASE=

# Where settled funds are sent. Your Agentic Wallet address on X Layer.
PAYDESK_PAYOUT_ADDRESS=0x...

# --- Required in production ---
# Base URL used to mint client-facing invoice links. If this is wrong, every
# link handed to a client is dead. On Railway: https://<your-app>.up.railway.app
PAYDESK_PUBLIC_URL=

# Persistent volume mount path. Railway's container filesystem is ephemeral —
# without this, every invoice is lost on redeploy.
PAYDESK_DATA_DIR=/data

# --- Optional ---
PAYDESK_BANK_DETAILS=
PORT=8080
# X402_ASSET_DECIMALS=6   # ASSUMED. Verify against OKX before taking real payments.

# Local UI development only. Returns canned agent output; never set in production.
# PAYDESK_DEMO_STUB=1
